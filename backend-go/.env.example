APP_ENV=development
PORT=8080
DATABASE_URL=data/app.db
PUBLIC_BASE_URL=http://localhost:8080
ADMIN_TOKEN=change-me-admin-token
PAYMENT_PROVIDER=mock
VPN_PROVIDER=mock
# Для CloudPayments:
# PAYMENT_PROVIDER=cloudpayments
# WEBHOOK URL в кабинете CloudPayments: https://your-domain.example/api/v1/payments/webhook
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=
# Для x-ui:
# VPN_PROVIDER=xui
# VPN_PROVIDER_ENDPOINT=http://127.0.0.1:54321
# VPN_PROVIDER_USERNAME=admin
# VPN_PROVIDER_PASSWORD=change-me
# VPN_PROVIDER_INBOUND_ID=1
# VPN_PROVIDER_PUBLIC_HOST=vpn.example.com
# VPN_PROVIDER_PUBLIC_PORT=443
# VPN_PROVIDER_REALITY_SERVER_NAME=www.cloudflare.com
# VPN_PROVIDER_REALITY_PUBLIC_KEY=
# VPN_PROVIDER_REALITY_SHORT_ID=
# VPN_PROVIDER_FLOW=xtls-rprx-vision
# VPN_PROVIDER_FINGERPRINT=chrome
# Для 3x-ui:
# VPN_PROVIDER=3xui
# VPN_PROVIDER_ENDPOINT=https://panel.example.com/secret-path
# VPN_PROVIDER_PUBLIC_HOST=vpn.example.com
# VPN_PROVIDER_PUBLIC_PORT=443
# VPN_PROVIDER_REALITY_SERVER_NAME=www.cloudflare.com
# VPN_PROVIDER_REALITY_PUBLIC_KEY=
# VPN_PROVIDER_REALITY_SHORT_ID=
# VPN_PROVIDER_FLOW=xtls-rprx-vision
# VPN_PROVIDER_FINGERPRINT=chrome
VPN_PROVIDER_ENDPOINT=
VPN_PROVIDER_TOKEN=
VPN_PROVIDER_USERNAME=
VPN_PROVIDER_PASSWORD=
VPN_PROVIDER_INBOUND_ID=
VPN_PROVIDER_PUBLIC_HOST=
VPN_PROVIDER_PUBLIC_PORT=443
VPN_PROVIDER_REALITY_SERVER_NAME=
VPN_PROVIDER_REALITY_PUBLIC_KEY=
VPN_PROVIDER_REALITY_SHORT_ID=
VPN_PROVIDER_FLOW=xtls-rprx-vision
VPN_PROVIDER_FINGERPRINT=chrome
SEED_PLANS_PATH=seed/plans.json
EXPIRER_INTERVAL_SECONDS=60
