package db

import (
	"encoding/json"
	"log"
	"os"

	"gorm.io/gorm"

	"vpn-bot/backend-go/internal/config"
	"vpn-bot/backend-go/internal/models"
)

type seedPlan struct {
	Name         string  `json:"name"`
	Price        float64 `json:"price"`
	DurationDays int     `json:"duration_days"`
	Description  string  `json:"description"`
}

func Seed(database *gorm.DB, cfg config.Config) {
	var count int64
	if err := database.Model(&models.Plan{}).Count(&count).Error; err != nil {
		log.Printf("seed count failed: %v", err)
		return
	}

	if count > 0 {
		return
	}

	raw, err := os.ReadFile(cfg.SeedPlansPath)
	if err != nil {
		log.Printf("seed read failed: %v", err)
		return
	}

	var plans []seedPlan
	if err := json.Unmarshal(raw, &plans); err != nil {
		log.Printf("seed parse failed: %v", err)
		return
	}

	for _, plan := range plans {
		record := models.Plan{
			Name:         plan.Name,
			Price:        plan.Price,
			DurationDays: plan.DurationDays,
			Description:  plan.Description,
			IsActive:     true,
		}

		if err := database.Create(&record).Error; err != nil {
			log.Printf("seed create failed: %v", err)
		}
	}
}

