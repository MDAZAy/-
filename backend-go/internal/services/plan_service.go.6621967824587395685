package services

import (
	"time"

	"vpn-bot/backend-go/internal/dto"
	"vpn-bot/backend-go/internal/models"
	"vpn-bot/backend-go/internal/repositories"
)

type PlanService struct {
	repo *repositories.PlanRepository
}

func NewPlanService(repo *repositories.PlanRepository) *PlanService {
	return &PlanService{repo: repo}
}

func (s *PlanService) ListActive() ([]models.Plan, error) {
	return s.repo.ListActive()
}

func (s *PlanService) ListAll() ([]models.Plan, error) {
	return s.repo.ListAll()
}

func (s *PlanService) Create(input dto.CreatePlanRequest) (*models.Plan, error) {
	plan := &models.Plan{
		Name:         input.Name,
		Price:        input.Price,
		DurationDays: input.DurationDays,
		Description:  input.Description,
		IsActive:     true,
		CreatedAt:    time.Now(),
	}

	return plan, s.repo.Create(plan)
}

