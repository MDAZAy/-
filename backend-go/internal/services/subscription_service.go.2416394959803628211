package services

import (
	"context"
	"errors"
	"time"

	"gorm.io/gorm"

	"vpn-bot/backend-go/internal/dto"
	"vpn-bot/backend-go/internal/models"
	"vpn-bot/backend-go/internal/providers"
	"vpn-bot/backend-go/internal/repositories"
)

type SubscriptionService struct {
	repo        *repositories.SubscriptionRepository
	planRepo    *repositories.PlanRepository
	vpnKeyRepo  *repositories.VPNKeyRepository
	vpnProvider providers.VPNProvider
}

func NewSubscriptionService(
	repo *repositories.SubscriptionRepository,
	planRepo *repositories.PlanRepository,
	vpnKeyRepo *repositories.VPNKeyRepository,
	vpnProvider providers.VPNProvider,
) *SubscriptionService {
	return &SubscriptionService{
		repo:        repo,
		planRepo:    planRepo,
		vpnKeyRepo:  vpnKeyRepo,
		vpnProvider: vpnProvider,
	}
}

func (s *SubscriptionService) Create(input dto.CreateSubscriptionRequest) (*models.Subscription, error) {
	plan, err := s.planRepo.GetByID(input.PlanID)
	if err != nil {
		return nil, err
	}

	now := time.Now()
	active, err := s.repo.GetActiveByUser(input.UserID, now)
	if err != nil && !errors.Is(err, gorm.ErrRecordNotFound) {
		return nil, err
	}

	if active != nil {
		active.PlanID = plan.ID
		active.EndAt = active.EndAt.AddDate(0, 0, plan.DurationDays)
		return active, s.repo.Save(active)
	}

	subscription := &models.Subscription{
		UserID:    input.UserID,
		PlanID:    plan.ID,
		Status:    "active",
		StartAt:   now,
		EndAt:     now.AddDate(0, 0, plan.DurationDays),
		CreatedAt: now,
	}

	return subscription, s.repo.Create(subscription)
}

func (s *SubscriptionService) GetActive(userID uint) (*models.Subscription, error) {
	return s.repo.GetActiveByUser(userID, time.Now())
}

func (s *SubscriptionService) ExpireDue(_ context.Context, now time.Time) error {
	subscriptions, err := s.repo.FindExpiredActive(now)
	if err != nil {
		return err
	}

	for i := range subscriptions {
		subscription := &subscriptions[i]
		subscription.Status = "expired"
		if err := s.repo.Save(subscription); err != nil {
			return err
		}

		key, err := s.vpnKeyRepo.FindActiveByUser(subscription.UserID)
		if err == nil {
			_ = s.vpnProvider.DeactivateKey(key.ExternalClientID)
		}

		if err := s.vpnKeyRepo.DeactivateAllByUser(subscription.UserID); err != nil {
			return err
		}
	}

	return nil
}

func (s *SubscriptionService) ListAll() ([]models.Subscription, error) {
	return s.repo.ListAll()
}

