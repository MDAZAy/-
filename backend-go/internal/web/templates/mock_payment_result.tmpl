<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Title}}</title>
    <style>
        body { font-family: Arial, sans-serif; background: #f4f7fb; margin: 0; min-height: 100vh; display: grid; place-items: center; color: #1f2937; }
        .card { width: min(520px, 92vw); background: #fff; border-radius: 20px; padding: 28px; box-shadow: 0 20px 60px rgba(0,0,0,0.08); }
        .ok { color: #15803d; }
        .fail { color: #b91c1c; }
    </style>
</head>
<body>
    <div class="card">
        <h1 class="{{if .Success}}ok{{else}}fail{{end}}">{{.Title}}</h1>
        <p>{{.Message}}</p>
        {{if .Payment}}
        <p>Payment ID: {{.Payment.ID}}</p>
        <p>Status: {{.Payment.Status}}</p>
        {{end}}
    </div>
</body>
</html>
