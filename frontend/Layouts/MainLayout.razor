@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject SessionState Session
@inject ApiClient Api

<MudThemeProvider Theme="@_theme" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Class="top-bar">
        <div class="brand-mark" @onclick="NavigateCabinet">
            <MudText Typo="Typo.h5">NordGarage</MudText>
        </div>
        <MudSpacer />
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="NavigateCabinet">Кабинет</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="NavigateVehicles">Мои авто</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="NavigateNewAppointment">Новая запись</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="NavigateHistory">История</MudButton>
        @if (Session.IsAdmin)
        {
            <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="NavigateAdmin">Админка</MudButton>
        }
        @if (Session.IsAuthenticated)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Warning" Class="logout-btn" OnClick="LogoutAsync">Выйти</MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="NavigateLogin">Вход</MudButton>
        }
    </MudAppBar>

    <MudMainContent>
        <div class="app-shell">
            @Body
        </div>
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#0f766e",
            Secondary = "#b45309",
            Background = "#f6f4ee",
            Surface = "#fffdf7",
            AppbarBackground = "#102a2c",
            AppbarText = "#f8fafc",
            DrawerBackground = "#fffdf7",
            DrawerText = "#102a2c",
            Success = "#2f855a",
            Warning = "#c2410c",
            Error = "#b91c1c",
            TextPrimary = "#162026",
            TextSecondary = "#5b6670"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = new[] { "Manrope", "Segoe UI", "sans-serif" }
            },
            H1 = new H1Typography { FontFamily = new[] { "Sora", "Manrope", "sans-serif" }, FontWeight = "700" },
            H2 = new H2Typography { FontFamily = new[] { "Sora", "Manrope", "sans-serif" }, FontWeight = "700" },
            H3 = new H3Typography { FontFamily = new[] { "Sora", "Manrope", "sans-serif" }, FontWeight = "700" },
            H4 = new H4Typography { FontFamily = new[] { "Sora", "Manrope", "sans-serif" }, FontWeight = "700" },
            H5 = new H5Typography { FontFamily = new[] { "Sora", "Manrope", "sans-serif" }, FontWeight = "700" }
        }
    };

    protected override async Task OnInitializedAsync()
    {
        await Session.InitializeAsync();
    }

    private async Task LogoutAsync()
    {
        try
        {
            await Api.LogoutAsync();
        }
        catch
        {
        }

        await Session.ClearAsync();
        Navigation.NavigateTo("/login");
    }

    private void NavigateCabinet() => Navigation.NavigateTo("/cabinet");
    private void NavigateVehicles() => Navigation.NavigateTo("/vehicles");
    private void NavigateNewAppointment() => Navigation.NavigateTo("/appointments/new");
    private void NavigateHistory() => Navigation.NavigateTo("/history");
    private void NavigateAdmin() => Navigation.NavigateTo("/admin");
    private void NavigateLogin() => Navigation.NavigateTo("/login");
}